@startuml
autonumber
skinparam Style strictuml

actor "Người dùng" as User
participant "ForgotPasswordScreen" as FE_Forgot
participant "ResetPasswordScreen" as FE_Reset
participant "AuthService (FE)" as AuthServiceFE
participant "AuthController" as Controller
participant "AuthService (BE)" as Service
participant "OtpService" as OtpSvc
participant "UserRepository" as Repo
participant "EmailService" as Email

== Giai đoạn 1: Quên mật khẩu ==

User -> FE_Forgot: Nhập Email
FE_Forgot -> AuthServiceFE: forgotPassword(email)

AuthServiceFE -> Controller: POST /api/auth/forgot-password (DTO)
activate Controller

Controller -> Service: forgotPassword(DTO)
activate Service

Service -> Repo: existsByEmail(email)
alt Email không tồn tại
    Service -> Controller: throw AppException("Email not found")
    Controller -> AuthServiceFE: 400 Bad Request
else Tìm thấy Email
    Service -> OtpSvc: generateAndStoreOtp(email, FORGOT_PASSWORD)
    Service -> Email: sendOtpEmail(email, otp)
    
    Service -> Controller: Success Response
    deactivate Service

    Controller -> AuthServiceFE: 200 OK
    deactivate Controller

    AuthServiceFE -> FE_Forgot: Thành công
    FE_Forgot -> User: Chuyển hướng sang Nhập OTP
end

== Giai đoạn 2: Đặt lại mật khẩu ==

User -> FE_Reset: Nhập OTP & Mật khẩu mới
FE_Reset -> AuthServiceFE: resetPassword(...)

AuthServiceFE -> Controller: POST /api/auth/reset-password (DTO)
activate Controller

Controller -> Service: resetPassword(DTO)
activate Service

Service -> OtpSvc: validateOtp(email, otp, FORGOT_PASSWORD)
alt OTP không hợp lệ/hết hạn
    Service -> Controller: throw AppException("Invalid OTP")
    Controller -> AuthServiceFE: 400 Bad Request
else OTP hợp lệ
    Service -> Repo: findByEmail(email)
    Service -> Service: Hash mật khẩu (BCrypt)
    Service -> Repo: save(User)
    Service -> OtpSvc: deleteOtp(...)
    
    Service -> Controller: Success Response
    deactivate Service

    Controller -> AuthServiceFE: 200 OK
    deactivate Controller

    AuthServiceFE -> FE_Reset: Thành công
    FE_Reset -> User: Thông báo & Chuyển sang Đăng nhập
end

@enduml
