@startuml UC08_FriendManagement
left to right direction
skinparam packageStyle rectangle
skinparam shadowing false

actor "Người dùng" as User

rectangle "Hệ thống Mapic - Quản lý Bạn bè" {

  ' Use Case chính
  usecase "Tìm kiếm theo tên/username" as UC_Search

  ' Hành động sau khi tìm thấy
  usecase "Gửi lời mời kết bạn" as UC_SendRequest
  usecase "Xem trang cá nhân" as UC_Profile

  ' Quản lý danh sách
  usecase "Xem danh sách bạn bè" as UC_FriendList
  usecase "Xem danh sách lời mời" as UC_Requests

  usecase "Hủy kết bạn" as UC_Unfriend
  usecase "Chấp nhận lời mời" as UC_Accept
  usecase "Từ chối lời mời" as UC_Decline
}

' Người dùng thực hiện các hành động chính
User --> UC_Search
User --> UC_FriendList
User --> UC_Requests

' Sau khi tìm thấy thì có thể gửi lời mời hoặc xem profile
UC_Search ..> UC_SendRequest : <<extend>>
UC_Search ..> UC_Profile : <<extend>>

' Các thao tác trên danh sách
UC_FriendList ..> UC_Profile : <<extend>>
UC_FriendList ..> UC_Unfriend : <<extend>>

UC_Requests ..> UC_Accept : <<extend>>
UC_Requests ..> UC_Decline : <<extend>>

note top of UC_Search
  Người dùng tìm kiếm bạn bè
  bằng tên hoặc username.
  Hỗ trợ tìm kiếm realtime.
end note

@enduml