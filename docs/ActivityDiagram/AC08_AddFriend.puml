@startuml AC08_AddFriend
title AC08 - Thêm bạn bè

skinparam conditionStyle InsideDiamond
skinparam shadowing false

start

:Mở màn hình "Thêm bạn bè";

:Nhập tên hoặc username vào ô tìm kiếm;

note right
  Tìm kiếm realtime với debounce 500ms
  Tự động tìm khi nhập >= 2 ký tự
end note

if (Có kết quả?) then (Có)
  :Hiển thị danh sách người dùng;
  
  :Chọn người dùng;
  
  if (Trạng thái quan hệ?) then (Chưa kết bạn)
    :Nhấn nút "Kết bạn";
    :Gửi lời mời kết bạn;
    :Hiển thị "Đã gửi";
    
  elseif (Đã gửi lời mời)
    :Hiển thị trạng thái "Đã gửi";
    note right: Có thể hủy lời mời
    
  elseif (Nhận được lời mời)
    :Hiển thị nút "Chấp nhận";
    :Chấp nhận lời mời;
    :Trở thành bạn bè;
    
  else (Đã là bạn bè)
    :Hiển thị "Bạn bè";
  endif
  
else (Không)
  :Hiển thị "Không tìm thấy";
endif

stop

@enduml
